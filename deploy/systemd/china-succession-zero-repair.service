[Unit]
Description=China Succession Zero Snapshot Repair
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=china-succession
Group=china-succession
WorkingDirectory=/opt/china-succession
EnvironmentFile=/etc/china-succession/china-succession.env
ExecStart=/opt/china-succession/.venv/bin/python -m app.tasks repair-zero-snapshots --limit 40 --workers 2
