APP_ENV=production
APP_PUBLIC_BASE_URL=https://your-domain.example.com
DATABASE_URL=postgresql+psycopg://your_user:your_password@your_host:5432/china_succession
APP_SECRET_KEY=replace_with_a_long_random_secret
APP_ADMIN_PASSWORD=replace_with_a_strong_admin_password
APP_SESSION_COOKIE_SECURE=true

# 站外提醒：二选一即可，两个都配也可以
ALERT_SMTP_HOST=smtp.example.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=alerts@example.com
ALERT_SMTP_PASSWORD=replace_with_smtp_password
ALERT_FROM_EMAIL=alerts@example.com

ALERT_WEBHOOK_URL=https://open.feishu.cn/your-webhook-or-other-webhook

# 可按生产环境调整
CNINFO_REQUEST_TIMEOUT=30
CNINFO_REQUEST_RETRIES=4
CNINFO_RETRY_BACKOFF_SECONDS=1.5
NOTICE_SYNC_DAYS_BACK=3
NOTICE_SYNC_PAGE_SIZE=40
NOTICE_SYNC_PAGE_LIMIT=12
NOTICE_PDF_PAGE_LIMIT=12
NOTICE_TEXT_CHAR_LIMIT=30000
LOW_CONFIDENCE_THRESHOLD=0.90

# AI 兜底抽取：只在规则抽取失败时调用。生产环境把 API Key 写入服务器环境变量，不要写入文档。
AI_EXTRACTION_ENABLED=false
AI_API_BASE_URL=https://api.minimaxi.com/anthropic
AI_MODEL_NAME=MiniMax-M2.7
AI_API_KEY=replace_with_ai_api_key
AI_REQUEST_TIMEOUT=60
AI_TEXT_CHAR_LIMIT=12000
